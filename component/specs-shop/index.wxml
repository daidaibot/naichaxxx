<!--component/specs/index.wxml-->
<popup id="popup">
  <view class="specs">
    <view class="flex" style="flex-direction: row;">
      <t-image t-class="specs-image" shape src="{{goodsSpec.check_attr.sku_pic}}"></t-image>
      <view class="flex pl-20" style="flex-direction: column;width: 525rpx;">
        <view class="flex" style="flex-direction: row; justify-content: space-between;margin-bottom: 40rpx;">
          <view class="specs-goods-name">{{goodsSpec.goods_title}}</view>
          <view class="flex">
            <iconfont icon="icon-del" color="#999999" size="40rpx" bindtap="hideSpecs" />
          </view>
        </view>
        <view class="flex justify-between">
          <view class="specs-price">￥{{goodsSpec.check_attr.selling_price}}</view>
          <view class="specs-num">库存：{{goodsSpec.check_attr.stock}}</view>
        </view>
      </view>
    </view>
    <view class="mt-20" wx:for="{{goodsSpec.goodsSpecParam}}" wx:key="unique">
      <view class="specs-title">{{item.name}}</view>
      <view class="specs-cell">
        <view class="specs-name {{children.checked?'specs-name-select':''}}" wx:for="{{item.list}}" wx:for-item="children" wx:key="unique" bindtap="clickSkuValue" data-value="{{children.name}}" data-item_value="{{item.name}}">{{children.name}}</view>
      </view>      
    </view>    
  </view>
  <view>
    <t-submit-bar t-class='button-submit' text='立即购买' bgcolor='{{main_color}}' z-index='9999' border self safeArea>
    <text style="position: fixed;margin-left: 30rpx;">备注信息</text>
    <view class="specs" style="margin-left: 507rpx; ">
      <van-cell-group> 
        <van-field custom-style="height:80rpx;margin-bottom:20rpx;margin-top:10rpx"    value="{{ number }}" placeholder="请输入数量" border="{{ false }}"    bind:change="onChangeNumber"/>
      </van-cell-group>
    </view>
      <view class="flex justify-between align-center pt-30 pl-20 pr-20 mb-15">        
        <view class="submit-btn-left" style="background: {{subColor}};" bindtap="order_car">加入购物车</view>
        <!-- <view class="submit-btn-right" style="background: {{mainColor}};" bindtap="order_pay">立即购买</view> -->
      </view>
    </t-submit-bar>
  </view>
</popup>