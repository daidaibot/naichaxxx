/* components/Navigation/index.wxss */
.navigation-wrap{ width: 90%; }
 
.fixed-nav-wrap{ 
  width: 90%;
  position: fixed;
  left: 5%; 
  bottom: 0; 
  z-index: 100;
  bottom: 40rpx;  
}

.fixed-nav-wrap .shadow-box{ 
  width: 100%; 
  min-height: 110rpx; 
  background-color: #ffffff;
  box-shadow: 0 0 10rpx rgba(0, 0, 0, .2); 
  position: relative; 
  z-index: 1; 
  box-shadow: 0 0 10rpx rgba(0, 0, 0, .2); 
  border-radius: 80rpx
  
}
.fixed-nav-wrap .shadow-box .middle-circle{ 
  width: 100rpx; 
  height: 100rpx; 
  margin-left: -45rpx;
  border-radius: 100rpx; 
  box-shadow: 0 0 10rpx rgba(0, 0, 0, .2); 
  background-color: #ffffff;
  position: absolute; 
  left: 50%; 
  top: -25rpx; 
  z-index: 1; 
}
.navigation-empty-wrap{ width: 100%; }
.navigation-empty-wrap .empty-box{ width: 100%; height: 100rpx; }
.bottom-safet-area{ background-color: #FFF; }
 
.fixed-nav-content{ 
  background-color: #ffffff; 
  width: 90%; 
  height: 90rpx; 
  position: absolute; 
  left: 5%; 
  top: 5%; 
  bottom: 160rpx;
  z-index: 5; 
}
.fixed-nav-content .table{ display: table; width: 100%; height: 100rpx; font-size: 26rpx; }
.fixed-nav-content .table .cell{ display: table-cell; vertical-align: middle; width: 1%; text-align: center; padding-top: 16rpx;}
.fixed-nav-content .table .cell.active{ color: #FF872E; }
.fixed-nav-content .scan{ width: 40rpx; height: 40rpx; position: relative; top: -10rpx; }
.tab_name{
  margin-top: -7rpx;
}

.tabbar_icon{
  width: 65rpx;
  height: 65rpx;
  }

  .tabbar_nav{
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    font-size: 20rpx;
    height: 50%;
    position: relative;
    padding-top: 63rpx;
    padding-bottom: 10rpx;
  }