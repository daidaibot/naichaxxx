}

.cash_submit{
  height: 60rpx;
  width: 100px;
  background: #2B91ED;
  color: #FFFFFF;
  display: flex;    /*设置显示样式**/
  flex-direction:column; /**子view排列方式row--水平 column--垂直*/
  align-items: center;    /**子view垂直居中*/
  vertical-align: center; /**垂直居中*/
  justify-content: center; /**内容居中*/ 
  border-radius: 50rpx !important;
  font-size: 28rpx;
  border: 1rpx solid #f3f3f3 !important;
  margin-top: 20rpx;
  margin-bottom: 10rpx;
 
}






