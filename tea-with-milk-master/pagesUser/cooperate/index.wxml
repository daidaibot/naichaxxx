<t-nav-bar title="商务合作" background="{{main_color}}" btn-color="{{nav_bar_btn_color}}" text-color="{{nav_bar_text_color}}" bind:home="routeToHome" />
<view class="opinion_wrap">
  <form bindsubmit="formSubmit">
      <view class="content_wrap">
          <view class="content">
              <textarea name="opinion"  maxlength="50" value="{{content}}" auto-height placeholder-class="placeholder" placeholder="留下您意见和需求，客服会在第一时间联系您（50字以内）" />
          </view>
      </view>  
      <view class="phone">
          <input name="contact" value="{{contact}}" placeholder-class="placeholder" placeholder="请留下您的手机号或邮箱，方便我们及时回复" />
      </view>
      <button formType="submit" hover-class="button_active" loading="{{loading}}">提交</button>
  </form>
</view>