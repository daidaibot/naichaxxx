  padding-right:15rpx; 
  padding-top: 20rpx;
  background-color: white;
  border-bottom: 1rpx solid #f3f3f3;
  height: 50rpx;
 
 
  
}
.income_top{
  display: flex;    /*设置显示样式**/
  flex-direction:column; /**子view排列方式row--水平 column--垂直*/
