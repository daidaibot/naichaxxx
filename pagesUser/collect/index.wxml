<!--pagesUser/collect/index.wxml-->
<view class="main">
  <t-nav-bar title="我的收藏" background="{{main_color}}" btn-color="{{nav_bar_btn_color}}" text-color="{{nav_bar_text_color}}" bind:home="routeToHome" />
    <view class="one_mian" wx:for="{{list}}" wx:for-item="item" wx:key="unique">
       <view class="mian_left">
          <text class="mt-20 text-lg text-bold">{{item.storage_shop_name}}</text>
          <view class="mt-15 flex">
             <view class="main_tag" style="background: {{main_color}};margin-right: 10rpx;"><text>可外卖</text></view>
             <view class="main_tag" style="background: {{main_color}};"><text>可自取</text></view>
          </view>
          <view class="mt-15 text-xs flex flex-direction">
          <view><van-icon name="location-o" size="35rpx" /><text class="ml-10">{{item.province}}{{item.city}}{{item.area}}{{item.address}}</text></view>
          <view class="mt-15"> <van-icon name="clock-o" size="35rpx"  /><text class="mt-15 ml-10">00:00-23:00</text></view>
          </view>
          <view class="mt-15 mb-20">
             <view>
                <van-button plain type="primary" size="mini" custom-style="margin-right:10rpx">营业中</van-button>
                <van-button  type="primary" size="mini">接受预定</van-button>
             </view>
          </view>
       </view>
       <view style="border-right: 1px solid #e2dede; margin-top: 30rpx; margin-bottom: 30rpx;margin-left: 10rpx;"></view>
       <view class="mian_right">
        <text style="margin-top: 85rpx; font-size: 30rpx;margin-left: 45rpx;">去下单</text>
        <text style="margin-top: 10rpx; font-size: 25rpx;margin-left: 20rpx;">距离{{item.GetDistance}}km</text>
        <view class="localtion" style="margin-left: 20rpx;">
              <view style="margin-top: 5rpx;"><van-icon name="location-o" info="常去" bind:click="openMap" size="24px"  data-item="{{item}}"/></view>
              <view style="margin-top: 5rpx;margin-left: 60rpx;"><van-icon name="phone-o"  size="24px" bindtap="tapMakePhoneCall" data-item="{{item}}" /></view>
        </view>
       </view>
    </view>

   

    

    


</view>